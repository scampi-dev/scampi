# Dotfiles
.*
!.gitignore
!.gitattributes
!.golangci.yml
!.gomarklint.json
!.mise.toml

# Template / example files want to be committed regardless of where
# they live (covers .env.example, .config.example, etc.).
!*.example

# CI
!/.forgejo/
!/.github/

# Developer environments
!.dev/

# Build and debug artifacts
/build/
site/static/scampi.png
site/static/scampi-sec.png
site/static/install.sh
__debug*
*.zip
*.out
*.test
