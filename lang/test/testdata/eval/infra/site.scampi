module main

// Translated from .infra/site.scampi (inlined)

import "std"
import "std/posix"

std.secrets { backend = std.SecretsBackend.age, path = "secrets.age.json" }

let vps = posix.ssh {
  name = "vps"
  host = "203.0.113.10"
  user = "hal9000"
}

std.deploy(name = "site", targets = [vps]) {
  let reload_caddy = posix.service {
    name = "caddy"
    state = posix.ServiceState.reloaded
  }

  posix.pkg { packages = ["caddy"], source = posix.pkg_system {} }

  posix.dir { path = "/var/www/scampi.dev", perm = "0755" }
  posix.dir { path = "/etc/caddy", perm = "0755", owner = "root", group = "root" }

  posix.copy {
    src = posix.source_local { path = "./files/Caddyfile" }
    dest = "/etc/caddy/Caddyfile"
    perm = "0644"
    owner = "root"
    group = "root"
    verify = "caddy validate --config %s"
    on_change = [reload_caddy]
  }

  posix.unarchive {
    src = posix.source_local { path = "./files/site.tar.gz" }
    dest = "/var/www/scampi.dev"
    owner = "hal9000"
    group = "hal9000"
  }

  posix.service { name = "caddy", state = posix.ServiceState.running, enabled = true }
}
