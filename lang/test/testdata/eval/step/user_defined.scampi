module main

import "std"
import "std/target"

type TeamMember {
  name: string
  groups: list[string] = []
}

decl create_user(member: TeamMember) Step {
  std.user { name = self.member.name, groups = self.member.groups }
  std.dir { path = "/home/${self.member.name}/.ssh" }
}

let vps = target.ssh { name = "vps", host = "10.0.0.1", user = "root" }

let team = [
  TeamMember { name = "alice", groups = ["wheel", "dev"] },
  TeamMember { name = "bob", groups = ["dev"] },
]

std.deploy {
  name = "users"
  targets = [vps]

  for m in team {
    create_user { member = m }
  }
}
