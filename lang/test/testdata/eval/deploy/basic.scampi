import "std"
import "std/target"

std.secrets { backend = "file", path = "secrets.json" }

let vps = target.ssh { name = "vps", host = "10.0.0.1", user = "root" }

std.deploy {
  name = "web"
  targets = [vps]

  std.pkg { packages = ["nginx", "certbot"], source = std.system {} }
  std.firewall { port = "80/tcp" }
  std.firewall { port = "443/tcp" }
  std.service { name = "nginx" }
}
