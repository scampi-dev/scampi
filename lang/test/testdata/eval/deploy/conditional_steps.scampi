module main

import "std"
import "std/posix"

let vps = posix.ssh { name = "vps", host = "10.0.0.1", user = "root" }

type Config {
  enable_firewall: bool
}

let cfg = Config { enable_firewall = true }

let firewall_steps = if cfg.enable_firewall { [posix.firewall { port = "80/tcp" }] } else { [] }

std.deploy {
  name = "conditional"
  targets = [vps]
  steps = [posix.pkg { packages = ["nginx"], source = posix.pkg_system {} }] + firewall_steps
}
