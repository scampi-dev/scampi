module main

import "std"
import "std/posix"

std.secrets { backend = std.SecretsBackend.age, path = "secrets.age.json" }

let host = "203.0.113.10"

let vps = posix.ssh {
  name = "vps"
  host = host
  user = "hal9000"
}

let runner_version = "12.7.2"
let runner_url = "https://example.com/runner/v${runner_version}/runner-linux-amd64"

type TeamMember {
  name: string
  groups: list[string] = []
  admin: bool = false
}

let team = [
  TeamMember { name = "alice", groups = ["wheel", "dev"], admin = true },
  TeamMember { name = "bob", groups = ["dev"] },
]

func base_packages(extra: list[string] = []) list[string] {
  let base = ["curl", "htop", "vim"]
  return base + extra
}

let packages = base_packages(["nginx", "certbot"])

std.deploy {
  name = "bootstrap"
  targets = [vps]
  steps = [
    posix.pkg { packages = packages, source = posix.pkg_system {} },

    posix.firewall { port = "22/tcp" },
    posix.firewall { port = "80/tcp" },
    posix.firewall { port = "443/tcp" },

    posix.dir { path = "/var/www/html" },

    posix.copy {
      src = posix.source_remote { url = runner_url }
      dest = "/usr/local/bin/runner"
      perm = "0755"
      owner = "root"
      group = "root"
    },

    posix.service { name = "nginx" },
  ]
}
