module main

import "std"
import "std/posix"
import "std/local"

let host = local.target { name = "host" }

std.deploy(name = "main", targets = [host]) {
  posix.template {
    dest  = "/tmp/out"
    perm  = "0644"
    owner = "root"
    group = "root"
    src   = posix.source_inline { content = "hello" }
    data  = {"env": 42}
  }
}
