// Auto-generated smoke test
// Verifies each generated function sends the expected method and path.

module spec

import "std"
import "std/rest"
import "std/test"
import "std/test/matchers"

let api = test.target_rest_mock(
  name = "api",
  base_url = "http://localhost",
  routes = {
    "GET /items": test.response(status = 200),
    "POST /items": test.response(status = 201),
    "PUT /items/1": test.response(status = 200),
    "DELETE /items/1": test.response(status = 204),
  },
  expect_requests = [
    test.request(method = "GET", path = "/items"),
    test.request(
      method = "POST",
      path   = "/items",
      body   = matchers.has_substring("\"name\""),
    ),
    test.request(
      method = "PUT",
      path   = "/items/1",
      body   = matchers.has_substring("\"name\""),
    ),
    test.request(method = "DELETE", path = "/items/1"),
  ],
)

std.deploy(name = "smoke", targets = [api]) {
  list_items(
    check = rest.status { code = 200 },
  )
  create_item(
    name = "test",
  )
  update_item(
    id = "1",
    name = "test",
  )
  delete_item(
    id = "1",
  )
}

