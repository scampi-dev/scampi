# Bench environment template — copy to bench/.env and edit to match
# your setup. bench/.env is gitignored so your real network details
# never land in the repo.
#
# bench/{provision,bench}.sh source this file first (defaults), then
# bench/.env (your overrides), then export everything so the
# provision/ phases, scampi/deploy.scampi, and the generated ansible
# inventory all see the same values.
#
# Every assignment uses the ${VAR:-default} form so a value already
# set in the calling environment wins over the file default — useful
# for ad-hoc tweaks like `RUNS=2 PHASES=cold bash bench/bench.sh`.

# ---- PVE host ----
# The Proxmox VE host that scampi reaches via SSH to provision LXCs.
# Leave PVE_HOST blank in this template; provision.sh will refuse to
# start until you set it in bench/.env.
PVE_HOST=${PVE_HOST:-}
PVE_USER=${PVE_USER:-root}
# Cluster node name as it appears in the PVE web UI (typically the hostname).
PVE_NODE=${PVE_NODE:-}

# ---- LXC network ----
# Bridge interface used by every bench LXC.
PVE_BRIDGE=${PVE_BRIDGE:-vmbr0}
# Default gateway inside each container.
PVE_GATEWAY=${PVE_GATEWAY:-}

# ---- VMID and IP allocation ----
# Bench LXCs use VMIDs base..base+BENCH_HOSTS-1 and IPs
# <prefix>.<base>..<prefix>.<base+BENCH_HOSTS-1>/24.
BENCH_VMID_BASE=${BENCH_VMID_BASE:-950}
BENCH_IP_PREFIX=${BENCH_IP_PREFIX:-}
BENCH_IP_BASE=${BENCH_IP_BASE:-200}

# ---- Scenario knobs (matrix axes) ----
# Number of LXCs in the bench fleet. provision.sh creates this many;
# bench.sh targets the first N. Re-running provision with a larger N
# creates additional LXCs without disturbing existing ones; smaller
# N leaves the extras alone (use teardown.scampi at matching N to
# remove). For matrix runs, provision once at the maximum value.
BENCH_HOSTS=${BENCH_HOSTS:-3}

# Simulated WAN egress delay applied to each LXC's eth0 via netem
# before timed runs. 0 = LAN (no extra latency). Approximates RTT
# (added to outgoing-from-LXC packets only, since the controller's
# inbound is what the bench commands wait on).
# Typical values: 50 (regional), 100 (cross-continental),
# 200 (intercontinental / satellite).
WAN_DELAY_MS=${WAN_DELAY_MS:-0}

# ---- Bench account ----
# Username created inside each LXC. Used by both scampi and ansible
# at bench time.
BENCH_USER=${BENCH_USER:-perf-user}

# ---- Snapshot ----
# ZFS snapshot name used as the cold-run rollback target.
SNAPSHOT_NAME=${SNAPSHOT_NAME:-pristine}

# ---- Workload pin ----
# nginx package version installed on each LXC. Single source of truth
# for both bench/scampi/deploy.scampi (via std.env) and
# bench/ansible/site.yml (via lookup('env', ...)). Bump when Debian
# stable security updates retire the current pin and re-baseline.
NGINX_VERSION=${NGINX_VERSION:-nginx=1.22.1-9+deb12u4}

# ---- Harness tunables ----
# Number of timed runs per (tool × phase). Lower for smoke tests.
RUNS=${RUNS:-10}
# Phases to run. Either "cold warm" or just one.
PHASES=${PHASES:-"cold warm"}
