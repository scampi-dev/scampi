<lexer>
  <config>
    <name>scampi</name>
    <alias>scampi</alias>
    <filename>*.scampi</filename>
    <mime_type>text/x-scampi</mime_type>
  </config>
  <rules>
    <state name="commentsandwhitespace">
      <rule pattern="//[^\n\r]*">
        <token type="CommentSingle"/>
      </rule>
      <rule pattern="/\*.*?\*/">
        <token type="CommentMultiline"/>
      </rule>
      <rule pattern="\s+">
        <token type="TextWhitespace"/>
      </rule>
    </state>

    <state name="interp">
      <rule pattern="&#34;">
        <token type="LiteralString"/>
        <pop depth="1"/>
      </rule>
      <rule pattern="\\.">
        <token type="LiteralStringEscape"/>
      </rule>
      <rule pattern="\$\{">
        <token type="LiteralStringInterpol"/>
        <push state="interp-inside"/>
      </rule>
      <rule pattern="\$">
        <token type="LiteralString"/>
      </rule>
      <rule pattern="[^&#34;\\$]+">
        <token type="LiteralString"/>
      </rule>
    </state>

    <state name="interp-inside">
      <rule pattern="\}">
        <token type="LiteralStringInterpol"/>
        <pop depth="1"/>
      </rule>
      <rule>
        <include state="root"/>
      </rule>
    </state>

    <state name="root">
      <rule>
        <include state="commentsandwhitespace"/>
      </rule>

      <rule pattern="&#34;">
        <token type="LiteralString"/>
        <push state="interp"/>
      </rule>

      <rule pattern="[0-9]+">
        <token type="LiteralNumberInteger"/>
      </rule>

      <rule pattern="\b(module|import|let|type|func|decl|enum|attribute)\b">
        <token type="KeywordDeclaration"/>
      </rule>

      <rule pattern="\b(for|in|if|else|return)\b">
        <token type="Keyword"/>
      </rule>

      <rule pattern="\b(true|false|null)\b">
        <token type="KeywordConstant"/>
      </rule>

      <rule pattern="\b(string|int|bool|float|any|list|map|block)\b">
        <token type="KeywordType"/>
      </rule>

      <rule pattern="\bself\b">
        <token type="NameBuiltinPseudo"/>
      </rule>

      <rule pattern="@[a-zA-Z_][\w.]*">
        <token type="NameDecorator"/>
      </rule>

      <rule pattern="\b[A-Z][\w]*\b">
        <token type="NameClass"/>
      </rule>

      <rule pattern="[a-zA-Z_]\w*(?=\s*\()">
        <token type="NameFunction"/>
      </rule>

      <rule pattern="[a-z_]\w*(?=\s*\{)">
        <token type="NameFunction"/>
      </rule>

      <rule pattern="(==|!=|&lt;=|&gt;=|&amp;&amp;|\|\||&lt;|&gt;|\+|\-|\*|/|%|!)">
        <token type="Operator"/>
      </rule>

      <rule pattern="[()\[\]{},.:;?@=]">
        <token type="Punctuation"/>
      </rule>

      <rule pattern="[a-zA-Z_]\w*">
        <token type="Text"/>
      </rule>
    </state>
  </rules>
</lexer>
