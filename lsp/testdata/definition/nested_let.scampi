module main

import "std"
import "std/posix"
import "std/local"

let host = local.target { name = "h" }

std.deploy(name = "t", targets = [host]) {
  let svc = posix.service { name = "nginx", state = posix.ServiceState.restarted }

  posix.copy {
    src = posix.source_local { path = "./nginx.conf" }
    dest = "/etc/nginx/nginx.conf"
    on_change = [sv$0c]
  }
}
