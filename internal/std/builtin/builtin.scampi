module builtin

// A sequence of characters.
pub type string

// A signed integer.
pub type int

// A truth value: true or false.
pub type bool

// Any type. Accepts all values.
pub type any

// An ordered, homogeneous collection.
pub type list

// A collection of key-value pairs.
pub type map

// A nested scope that produces steps or declarations.
pub type block
