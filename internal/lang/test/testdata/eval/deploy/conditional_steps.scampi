module main

import "std"
import "std/posix"
import "std/ssh"

let vps = ssh.target { name = "vps", host = "10.0.0.1", user = "root" }

type Config {
  enable_firewall: bool
}

let cfg = Config { enable_firewall = true }

let firewall_steps = if cfg.enable_firewall { [posix.firewall { port = 80 }] } else { [] }

std.deploy(name = "conditional", targets = [vps]) {
  posix.pkg { packages = ["nginx"], source = posix.pkg_system {} }

  for step in firewall_steps {
    step
  }
}
