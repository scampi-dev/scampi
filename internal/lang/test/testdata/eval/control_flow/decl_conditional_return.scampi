module main

import "std"
import "std/posix"
import "std/local"

decl maybe_dir(make: bool, p: string) std.Step {
  if make {
    return posix.dir { path = p }
  }
}

let host = local.target { name = "local" }

std.deploy(name = "test", targets = [host]) {
  maybe_dir { make = true,  p = "/a" }
  maybe_dir { make = false, p = "/b" }
}
