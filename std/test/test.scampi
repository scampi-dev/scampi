// SPDX-License-Identifier: GPL-3.0-only

module test

import "std"
import "std/posix"
import "std/test/matchers"

// Mock target backends for testing scampi configs.
//
// Tests are scampi configs that:
//   1. construct one or more mock targets via `test.target_*` here
//   2. include a `std.deploy(...)` that runs against those mocks
//   3. carry expected end state on each mock as data
//
// The runner applies the deploy and verifies each mock's recorded
// state against its declared `expect` field. There is no assertion
// API — the mock IS the assertion.
//
// See docs/test-framework.md for the full design.

// Opaque types
// -----------------------------------------------------------------------------

// Response is a canned HTTP response replayed by rest_mock when a
// matching request comes in.
pub type Response

// RequestMatcher is a request shape declaration consumed by
// rest_mock's verification phase. Each one matches zero or more
// recorded requests by method/path/body/headers/cardinality.
pub type RequestMatcher

// Initial / expected state shapes
// -----------------------------------------------------------------------------

// State seeded into a mock target before the deploy runs. Reuses the
// same source composables real configs use — files take a
// posix.Source, services take posix.ServiceState, etc. There's no
// test-only language for "how to provide content".
pub type InitialState {
  files:    map[string, posix.Source]?
  packages: list[string]?
  services: map[string, posix.ServiceState]?
  dirs:     list[string]?
  symlinks: map[string, string]?
}

// State expected on a mock target after the deploy runs. Every entry
// is a matchers.Matcher — the runner dispatches by slot and verifies
// at the end of apply. Files NOT listed in `expect.files` are
// unconstrained; absences are stated explicitly via
// `matchers.is_absent()`.
pub type ExpectedState {
  files:    map[string, matchers.Matcher]?
  packages: map[string, matchers.Matcher]?
  services: map[string, matchers.Matcher]?
  dirs:     map[string, matchers.Matcher]?
  symlinks: map[string, matchers.Matcher]?
}

// Target constructors
// -----------------------------------------------------------------------------

// All test target constructors return std.Target so they compose
// directly into `std.deploy(targets = [...])`. The runner identifies
// "test target" instances via a per-run registry built during eval,
// not via the type system.

// In-memory POSIX target. The mock implements file/dir/package/
// service/symlink ops against an internal map. State is recorded for
// later verification.
//
// `initial` is optional — omit it for tests that start from blank
// state. `expect` is optional — omit it for smoke tests that only
// verify the deploy applies cleanly.
pub func target_in_memory(
  name:    string
  initial: InitialState?
  expect:  ExpectedState?
) std.Target

// REST API mock. Records every request the engine makes; replays
// canned responses defined by `routes`. Requests can be verified
// against `expect_requests` matchers after apply.
//
// Route keys are "METHOD /path" strings, e.g. "POST /v1/sites".
// `expect_requests` is a list of test.request(...) values; order
// doesn't matter, cardinality defaults to "at least once".
pub func target_rest_mock(
  name:            string
  base_url:        string
  routes:          map[string, Response]
  expect_requests: list[RequestMatcher]?
) std.Target

// Response and request builders
// -----------------------------------------------------------------------------

// Build a canned HTTP response for use in `routes`. `body` is sent
// verbatim; `headers` are merged with sensible defaults
// (Content-Type defaults to "application/json" if not set).
pub func response(
  status:  int
  body:    string?
  headers: map[string, string]?
) Response

// Build a request matcher for use in `expect_requests`. `body` is a
// matchers.Matcher so partial / regex / exact matching all work.
//
// Cardinality:
//   - count = N         exactly N matching requests
//   - count_at_least = N at least N matching requests (default 1)
// Set neither for the default (at least one match).
pub func request(
  method:         string
  path:           string
  body:           matchers.Matcher?
  count:          int?
  count_at_least: int?
) RequestMatcher
