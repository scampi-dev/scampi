module matchers

import "std/posix"

// Matchers describe expected end-state on a test target. They live
// in `expect.files`, `expect.packages`, `expect.services`, etc., and
// in the `body` field of `test.request(...)`. The runner dispatches
// each matcher by the slot it appears in (file content vs package
// status vs service status vs request body) and emits a typed
// diagnostic if a matcher doesn't make sense in its slot.
//
// All matchers return the same opaque `Matcher` type. Type safety is
// at the human-readable layer (function names) rather than the
// type-checker layer — the slot validation runs at verify time.
//
// See docs/test-framework.md for the design rationale.

// Opaque matcher type. The runner knows how to evaluate it.
pub type Matcher

// String-content matchers
// -----------------------------------------------------------------------------
//
// Work in slots that compare a string against an observed string:
// file contents, request body, header value.

// Observed content must equal `content` byte-for-byte.
pub func has_exact_content(content: string) Matcher

// Observed content must contain `substring` as a substring.
pub func has_substring(substring: string) Matcher

// Observed content must match `pattern` as a Go regular expression.
pub func matches_regex(pattern: string) Matcher

// Observed content must be the empty string. Distinct from
// `is_absent()` — `is_empty()` requires the slot to exist with
// zero-length content.
pub func is_empty() Matcher

// Existence matchers
// -----------------------------------------------------------------------------
//
// Work in any keyed slot — files, packages, services, dirs, symlinks.

// Slot must be present (any content / any state).
pub func is_present() Matcher

// Slot must NOT be present at the end of the deploy.
pub func is_absent() Matcher

// Status matchers
// -----------------------------------------------------------------------------
//
// Parameterized by the existing posix enums so the test vocabulary
// matches the production vocabulary one-for-one.

// Service status check. Use the existing posix.ServiceState values:
// running, stopped, restarted, ...
pub func has_svc_status(status: posix.ServiceState) Matcher

// Package status check. Use the existing posix.PkgState values:
// present, absent, latest.
pub func has_pkg_status(status: posix.PkgState) Matcher
